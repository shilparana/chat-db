# Azure OpenAI Configuration (Primary)
AZURE_OPENAI_API_KEY=your_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://oai-instance1-sr.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Tavily Search API (optional - will use mock data if not set)
TAVILY_API_KEY=your_openai_api_key_here
USE_TAVILY=true

# LangSmith Tracing (optional - for monitoring)
LANGCHAIN_API_KEY=your_openai_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=db_chat

# Logging Configuration
LOG_LEVEL=INFO

